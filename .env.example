# === Claude API ===
# Anthropic コンソール (https://console.anthropic.com) で取得
ANTHROPIC_API_KEY=sk-ant-...

# === Gmail SMTP ===
GMAIL_USER=yourname@gmail.com
# Gmailアプリパスワード（16文字、スペースなし）
# 取得方法: https://myaccount.google.com/apppasswords
# ※ Googleアカウントの2段階認証が必須です
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# === メール設定 ===
EMAIL_FROM="News Digest <yourname@gmail.com>"
# 複数の宛先はカンマ区切り
EMAIL_TO=yourname@gmail.com
EMAIL_SUBJECT=今日のニュースダイジェスト

# === ニュースソース（パイプ区切り: ラベル|URL|ラベル|URL） ===
RSS_FEEDS=NHKニュース|https://www.nhk.or.jp/rss/news/cat0.xml|朝日新聞|https://www.asahi.com/rss/asahi/newsheadlines.rdf|日本経済新聞|https://www.nikkei.com/news/rss/news.rdf

# === フィルタリング設定 ===
# 直近何時間以内の記事を対象にするか（デフォルト: 24）
ARTICLE_MAX_AGE_HOURS=24
# ソースごとの最大記事数（デフォルト: 5）
MAX_ARTICLES_PER_SOURCE=5

# === Claude モデル ===
# claude-haiku-4-5（安価）/ claude-sonnet-4-6（高品質）
CLAUDE_MODEL=claude-haiku-4-5

# === ログレベル ===
# debug / info / warn / error
LOG_LEVEL=info
